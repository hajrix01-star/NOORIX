# Noorix — متغيرات البيئة (انسخ إلى .env وعدّل القيم)
# لا ترفع ملف .env إلى المستودع

# عنوان الـ API (Backend). إن تركت فارغاً تُستخدم طلبات محلية/mock.
VITE_API_URL=

# للتشغيل المحلي مع الـ Backend على المنفذ 3000:
# VITE_API_URL=http://localhost:3000

# مثال للإنتاج:
# VITE_API_URL=https://api.noorix.example.com
