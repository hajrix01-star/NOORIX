{
  "name": "noorix-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Noorix ERP Backend — NestJS + Prisma + PostgreSQL",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "prestart:dev": "powershell -ExecutionPolicy Bypass -File ../scripts/kill-port.ps1 -Port 3000",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:prod:full": "npx prisma migrate deploy && node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma migrate deploy",
    "db:delete-vip-moallim": "node prisma/delete-companies.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "moment-timezone": "^0.5.46",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "typescript": "^5.6.3"
  }
}
