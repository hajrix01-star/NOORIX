# Noorix Backend — copy to .env and set values
PORT=3000
# للـ Supabase: استخدم Connection Pooler (Transaction mode، منفذ 6543) من Project Settings → Database
# Direct (db.xxx.supabase.co:5432) محدود جداً — يؤدي إلى MaxClientsInSessionMode على Render
# DATABASE_CONNECTION_LIMIT=3  # اختياري — يحد اتصالات Prisma (افتراضي 3 لـ Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/noorix?schema=public"
JWT_SECRET=your-secret-min-32-chars-change-in-production
JWT_EXPIRES_IN=8h

# Gemini API — لفهم النية في المحادثة الذكية (اختياري)
# احصل على المفتاح من: https://aistudio.google.com/app/apikey
# عند عدم التعريف: يعمل النظام بمطابقة الكلمات المفتاحية
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # أو gemini-3-flash-preview
# GEMINI_OPEN_MODE=true           # true = يجيب على أي سؤال (تحيات، عام). false = نطاق النظام فقط

# ── النسخ الاحتياطي (محلي + اختياري Google Apps Script مثل workflow GitHub) ──
# BACKUP_LOCAL_DIR=./data/backups
# الجدولة اليومية والساعة والاحتفاظ بـ N نسخة: من الإعدادات → النسخ الاحتياطي → «نسخ النظام» (مالك/مدير) — جدول system_backup_config
# عند أول تشغيل بدون صف إعدادات: إن وُجد BACKUP_DAILY_ENABLED=true يُنشأ الصف بـ enabled=true (توافق قديم)
# BACKUP_DAILY_ENABLED=false
# BACKUP_GDRIVE_SCRIPT_URL=       # نفس GDRIVE_SCRIPT_URL أو رابط منفصل لرفع النسخ من التطبيق
